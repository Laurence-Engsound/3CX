<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1400 1080" font-family="Microsoft JhengHei, Noto Sans CJK TC, sans-serif">
  <defs>
    <!-- Gradients -->
    <linearGradient id="gUser" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#F7FAFC"/>
      <stop offset="100%" stop-color="#E2E8F0"/>
    </linearGradient>
    <linearGradient id="gExp" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#F0FFF4"/>
      <stop offset="100%" stop-color="#C6F6D5"/>
    </linearGradient>
    <linearGradient id="gVox" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#EBF8FF"/>
      <stop offset="100%" stop-color="#BEE3F8"/>
    </linearGradient>
    <linearGradient id="gPbx" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFFAF0"/>
      <stop offset="100%" stop-color="#FEEBC8"/>
    </linearGradient>
    <linearGradient id="gEnv" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#F7FAFC"/>
      <stop offset="100%" stop-color="#E2E8F0"/>
    </linearGradient>

    <linearGradient id="cardGreen" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFFFFF"/>
      <stop offset="100%" stop-color="#F0FFF4"/>
    </linearGradient>
    <linearGradient id="cardBlue" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFFFFF"/>
      <stop offset="100%" stop-color="#EBF8FF"/>
    </linearGradient>
    <linearGradient id="cardOrange" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFFFFF"/>
      <stop offset="100%" stop-color="#FFFAF0"/>
    </linearGradient>
    <linearGradient id="cardGray" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFFFFF"/>
      <stop offset="100%" stop-color="#F7FAFC"/>
    </linearGradient>

    <!-- Drop shadow filter -->
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="2"/>
      <feOffset dx="2" dy="3" result="offsetblur"/>
      <feComponentTransfer><feFuncA type="linear" slope="0.18"/></feComponentTransfer>
      <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>

    <!-- Arrows -->
    <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#4A5568"/>
    </marker>
    <marker id="arrowDash" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#718096"/>
    </marker>

    <!-- ================== ICON SYMBOLS ================== -->
    <!-- icAgent: 座席（耳機人頭） -->
    <symbol id="icAgent" viewBox="0 0 40 40">
      <circle cx="20" cy="14" r="7" fill="#4A5568"/>
      <path d="M 8 32 Q 8 22 20 22 Q 32 22 32 32 Z" fill="#4A5568"/>
      <path d="M 11 14 Q 11 8 20 8 Q 29 8 29 14" stroke="#2D3748" stroke-width="2" fill="none"/>
      <rect x="9" y="14" width="3" height="6" rx="1.5" fill="#2D3748"/>
      <rect x="28" y="14" width="3" height="6" rx="1.5" fill="#2D3748"/>
    </symbol>
    <!-- icSup: 主管（領帶人頭） -->
    <symbol id="icSup" viewBox="0 0 40 40">
      <circle cx="20" cy="13" r="7" fill="#2C5282"/>
      <path d="M 8 32 Q 8 21 20 21 Q 32 21 32 32 Z" fill="#2C5282"/>
      <polygon points="18,21 22,21 21,32 19,32" fill="#E53E3E"/>
    </symbol>
    <!-- icCust: 客戶（手機+人頭） -->
    <symbol id="icCust" viewBox="0 0 40 40">
      <circle cx="14" cy="13" r="6" fill="#805AD5"/>
      <path d="M 4 30 Q 4 21 14 21 Q 24 21 24 30 Z" fill="#805AD5"/>
      <rect x="26" y="10" width="11" height="20" rx="2" fill="#2D3748"/>
      <rect x="27.5" y="12" width="8" height="13" fill="#A0AEC0"/>
      <circle cx="31.5" cy="27.5" r="0.8" fill="#A0AEC0"/>
    </symbol>
    <!-- icAudit: 質檢（放大鏡+文件） -->
    <symbol id="icAudit" viewBox="0 0 40 40">
      <rect x="6" y="6" width="20" height="26" rx="2" fill="#FFFFFF" stroke="#4A5568" stroke-width="1.5"/>
      <line x1="9" y1="13" x2="22" y2="13" stroke="#4A5568" stroke-width="1.2"/>
      <line x1="9" y1="17" x2="22" y2="17" stroke="#4A5568" stroke-width="1.2"/>
      <line x1="9" y1="21" x2="20" y2="21" stroke="#4A5568" stroke-width="1.2"/>
      <circle cx="29" cy="26" r="6" fill="none" stroke="#C53030" stroke-width="2.5"/>
      <line x1="33" y1="30" x2="38" y2="35" stroke="#C53030" stroke-width="2.5" stroke-linecap="round"/>
    </symbol>
    <!-- icMonitor: 桌面螢幕 -->
    <symbol id="icMonitor" viewBox="0 0 40 40">
      <rect x="4" y="6" width="32" height="22" rx="2" fill="#2D3748"/>
      <rect x="6" y="8" width="28" height="18" fill="#48BB78"/>
      <rect x="17" y="28" width="6" height="4" fill="#2D3748"/>
      <rect x="12" y="32" width="16" height="3" rx="1" fill="#2D3748"/>
    </symbol>
    <!-- icDashboard: 儀表板（圓餅+柱） -->
    <symbol id="icDashboard" viewBox="0 0 40 40">
      <rect x="3" y="6" width="34" height="24" rx="2" fill="#2D3748"/>
      <rect x="5" y="8" width="30" height="20" fill="#FFFFFF"/>
      <rect x="8" y="20" width="3" height="6" fill="#3182CE"/>
      <rect x="13" y="16" width="3" height="10" fill="#3182CE"/>
      <rect x="18" y="13" width="3" height="13" fill="#3182CE"/>
      <circle cx="29" cy="18" r="6" fill="none" stroke="#48BB78" stroke-width="2"/>
      <path d="M 29 12 A 6 6 0 0 1 35 18" stroke="#ED8936" stroke-width="2" fill="none"/>
      <rect x="12" y="32" width="16" height="3" rx="1" fill="#2D3748"/>
    </symbol>
    <!-- icRec: 錄音（圓盤+三角播放） -->
    <symbol id="icRec" viewBox="0 0 40 40">
      <circle cx="20" cy="20" r="15" fill="#2D3748"/>
      <circle cx="20" cy="20" r="11" fill="#4A5568"/>
      <circle cx="20" cy="20" r="3" fill="#FFFFFF"/>
      <circle cx="20" cy="11" r="2" fill="#E53E3E"/>
    </symbol>
    <!-- icWallboard: 大螢幕 -->
    <symbol id="icWallboard" viewBox="0 0 40 40">
      <rect x="3" y="5" width="34" height="25" rx="1" fill="#2D3748"/>
      <rect x="5" y="7" width="30" height="21" fill="#1A202C"/>
      <text x="20" y="20" text-anchor="middle" fill="#48BB78" font-size="10" font-weight="bold" font-family="monospace">KPI</text>
      <rect x="14" y="30" width="12" height="3" fill="#2D3748"/>
      <rect x="10" y="33" width="20" height="3" rx="1" fill="#2D3748"/>
    </symbol>
    <!-- icRoute: 路由（節點+連線） -->
    <symbol id="icRoute" viewBox="0 0 40 40">
      <circle cx="8" cy="20" r="4" fill="#3182CE"/>
      <circle cx="32" cy="10" r="4" fill="#3182CE"/>
      <circle cx="32" cy="30" r="4" fill="#3182CE"/>
      <line x1="12" y1="20" x2="28" y2="10" stroke="#3182CE" stroke-width="2"/>
      <line x1="12" y1="20" x2="28" y2="30" stroke="#3182CE" stroke-width="2"/>
    </symbol>
    <!-- icRules: 規則（齒輪簡化） -->
    <symbol id="icRules" viewBox="0 0 40 40">
      <path d="M 20 6 L 23 8 L 27 7 L 28 11 L 32 13 L 31 17 L 34 20 L 31 23 L 32 27 L 28 29 L 27 33 L 23 32 L 20 34 L 17 32 L 13 33 L 12 29 L 8 27 L 9 23 L 6 20 L 9 17 L 8 13 L 12 11 L 13 7 L 17 8 Z" fill="#3182CE"/>
      <circle cx="20" cy="20" r="5" fill="#FFFFFF"/>
    </symbol>
    <!-- icDialog: 對話泡泡 -->
    <symbol id="icDialog" viewBox="0 0 40 40">
      <path d="M 5 8 L 28 8 Q 32 8 32 12 L 32 22 Q 32 26 28 26 L 14 26 L 8 32 L 9 26 Q 5 26 5 22 Z" fill="#3182CE"/>
      <circle cx="13" cy="17" r="1.8" fill="#FFFFFF"/>
      <circle cx="19" cy="17" r="1.8" fill="#FFFFFF"/>
      <circle cx="25" cy="17" r="1.8" fill="#FFFFFF"/>
    </symbol>
    <!-- icDb: 資料庫圓柱 -->
    <symbol id="icDb" viewBox="0 0 40 40">
      <ellipse cx="20" cy="9" rx="13" ry="4" fill="#3182CE"/>
      <path d="M 7 9 L 7 31 Q 7 35 20 35 Q 33 35 33 31 L 33 9" fill="#3182CE"/>
      <ellipse cx="20" cy="9" rx="13" ry="4" fill="#63B3ED"/>
      <ellipse cx="20" cy="18" rx="13" ry="4" fill="none" stroke="#FFFFFF" stroke-width="1.5"/>
      <ellipse cx="20" cy="26" rx="13" ry="4" fill="none" stroke="#FFFFFF" stroke-width="1.5"/>
    </symbol>
    <!-- icShield: 資安盾牌 -->
    <symbol id="icShield" viewBox="0 0 40 40">
      <path d="M 20 4 L 34 9 L 34 22 Q 34 32 20 36 Q 6 32 6 22 L 6 9 Z" fill="#C53030"/>
      <path d="M 14 20 L 18 24 L 26 14" stroke="#FFFFFF" stroke-width="2.5" fill="none" stroke-linecap="round"/>
    </symbol>
    <!-- icObs: 觀測（折線圖） -->
    <symbol id="icObs" viewBox="0 0 40 40">
      <rect x="4" y="6" width="32" height="28" rx="2" fill="#FFFFFF" stroke="#DD6B20" stroke-width="1.5"/>
      <polyline points="8,28 14,18 20,22 26,12 32,16" fill="none" stroke="#DD6B20" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="14" cy="18" r="2" fill="#DD6B20"/>
      <circle cx="26" cy="12" r="2" fill="#DD6B20"/>
    </symbol>
    <!-- icDevops: DevOps 無限符號 -->
    <symbol id="icDevops" viewBox="0 0 40 40">
      <path d="M 12 20 Q 8 14 14 14 Q 20 14 20 20 Q 20 26 26 26 Q 32 26 28 20 Q 32 14 26 14 Q 20 14 20 20 Q 20 26 14 26 Q 8 26 12 20 Z" fill="none" stroke="#805AD5" stroke-width="3"/>
    </symbol>
    <!-- icGov: 治理天平 -->
    <symbol id="icGov" viewBox="0 0 40 40">
      <line x1="20" y1="6" x2="20" y2="32" stroke="#22543D" stroke-width="2"/>
      <line x1="6" y1="12" x2="34" y2="12" stroke="#22543D" stroke-width="2"/>
      <path d="M 6 12 L 2 22 Q 6 26 10 22 Z" fill="#48BB78" stroke="#22543D" stroke-width="1.5"/>
      <path d="M 34 12 L 30 22 Q 34 26 38 22 Z" fill="#48BB78" stroke="#22543D" stroke-width="1.5"/>
      <rect x="14" y="30" width="12" height="4" fill="#22543D"/>
    </symbol>
    <!-- icAi: AI 機器人頭 -->
    <symbol id="icAi" viewBox="0 0 40 40">
      <rect x="8" y="10" width="24" height="20" rx="4" fill="#ED8936"/>
      <circle cx="14" cy="20" r="3" fill="#FFFFFF"/>
      <circle cx="26" cy="20" r="3" fill="#FFFFFF"/>
      <circle cx="14" cy="20" r="1.2" fill="#2D3748"/>
      <circle cx="26" cy="20" r="1.2" fill="#2D3748"/>
      <line x1="20" y1="10" x2="20" y2="6" stroke="#ED8936" stroke-width="2"/>
      <circle cx="20" cy="5" r="2" fill="#ED8936"/>
      <line x1="14" y1="28" x2="26" y2="28" stroke="#FFFFFF" stroke-width="1.5"/>
    </symbol>
    <!-- icAdapter: 整合插頭 -->
    <symbol id="icAdapter" viewBox="0 0 40 40">
      <rect x="6" y="14" width="20" height="12" rx="2" fill="#3182CE"/>
      <line x1="26" y1="17" x2="32" y2="17" stroke="#3182CE" stroke-width="3"/>
      <line x1="26" y1="23" x2="32" y2="23" stroke="#3182CE" stroke-width="3"/>
      <rect x="32" y="14" width="4" height="12" fill="#2C5282"/>
      <circle cx="11" cy="20" r="2" fill="#FFFFFF"/>
      <circle cx="17" cy="20" r="2" fill="#FFFFFF"/>
      <circle cx="22" cy="20" r="2" fill="#FFFFFF"/>
    </symbol>
    <!-- icPbx: PBX 機箱+電話 -->
    <symbol id="icPbx" viewBox="0 0 40 40">
      <rect x="6" y="14" width="28" height="18" rx="2" fill="#DD6B20"/>
      <rect x="9" y="17" width="22" height="3" fill="#FFFFFF"/>
      <circle cx="11" cy="25" r="1.5" fill="#FFFFFF"/>
      <circle cx="16" cy="25" r="1.5" fill="#FFFFFF"/>
      <circle cx="21" cy="25" r="1.5" fill="#FFFFFF"/>
      <circle cx="26" cy="25" r="1.5" fill="#FFFFFF"/>
      <circle cx="31" cy="25" r="1.5" fill="#FFFFFF"/>
      <path d="M 14 6 Q 14 10 16 10 L 24 10 Q 26 10 26 6 L 22 6 Q 21 8 19 8 L 18 8 Q 16 6 14 6 Z" fill="#7C2D12"/>
    </symbol>
    <!-- icBot: 致行 OUTREACH（電話+AI） -->
    <symbol id="icBot" viewBox="0 0 40 40">
      <rect x="10" y="8" width="20" height="20" rx="3" fill="#48BB78"/>
      <circle cx="16" cy="16" r="2" fill="#FFFFFF"/>
      <circle cx="24" cy="16" r="2" fill="#FFFFFF"/>
      <path d="M 14 22 Q 20 25 26 22" stroke="#FFFFFF" stroke-width="2" fill="none" stroke-linecap="round"/>
      <path d="M 6 30 Q 6 34 10 36 L 14 36 L 12 32 Q 8 30 6 30" fill="#22543D"/>
    </symbol>
    <!-- icOpen: OPEN/TeleSA（多人外撥） -->
    <symbol id="icOpen" viewBox="0 0 40 40">
      <rect x="3" y="8" width="34" height="24" rx="2" fill="#48BB78"/>
      <rect x="5" y="10" width="30" height="20" fill="#FFFFFF"/>
      <text x="20" y="22" text-anchor="middle" fill="#22543D" font-size="9" font-weight="bold">OPEN</text>
      <text x="20" y="28" text-anchor="middle" fill="#22543D" font-size="6">TeleSA</text>
    </symbol>
    <!-- icNas: NAS 儲存 -->
    <symbol id="icNas" viewBox="0 0 40 40">
      <rect x="6" y="8" width="28" height="6" rx="1" fill="#4A5568"/>
      <rect x="6" y="16" width="28" height="6" rx="1" fill="#4A5568"/>
      <rect x="6" y="24" width="28" height="6" rx="1" fill="#4A5568"/>
      <circle cx="30" cy="11" r="1" fill="#48BB78"/>
      <circle cx="30" cy="19" r="1" fill="#48BB78"/>
      <circle cx="30" cy="27" r="1" fill="#48BB78"/>
    </symbol>
    <!-- icAd: AD/SSO 鑰匙 -->
    <symbol id="icAd" viewBox="0 0 40 40">
      <circle cx="14" cy="20" r="8" fill="none" stroke="#4A5568" stroke-width="3"/>
      <line x1="22" y1="20" x2="36" y2="20" stroke="#4A5568" stroke-width="3"/>
      <line x1="30" y1="20" x2="30" y2="26" stroke="#4A5568" stroke-width="3"/>
      <line x1="34" y1="20" x2="34" y2="24" stroke="#4A5568" stroke-width="3"/>
    </symbol>
    <!-- icCrm: CRM 客戶卡 -->
    <symbol id="icCrm" viewBox="0 0 40 40">
      <rect x="5" y="9" width="30" height="22" rx="2" fill="#FFFFFF" stroke="#4A5568" stroke-width="1.5"/>
      <circle cx="13" cy="18" r="4" fill="#4A5568"/>
      <path d="M 7 28 Q 7 22 13 22 Q 19 22 19 28" fill="#4A5568"/>
      <line x1="22" y1="14" x2="32" y2="14" stroke="#4A5568" stroke-width="1.5"/>
      <line x1="22" y1="18" x2="32" y2="18" stroke="#4A5568" stroke-width="1.5"/>
      <line x1="22" y1="22" x2="32" y2="22" stroke="#4A5568" stroke-width="1.5"/>
      <line x1="22" y1="26" x2="29" y2="26" stroke="#4A5568" stroke-width="1.5"/>
    </symbol>
    <!-- icTrunk: 電信 trunk 信號塔 -->
    <symbol id="icTrunk" viewBox="0 0 40 40">
      <polygon points="14,32 20,8 26,32" fill="#4A5568"/>
      <line x1="16" y1="22" x2="24" y2="22" stroke="#FFFFFF" stroke-width="1.2"/>
      <line x1="17" y1="16" x2="23" y2="16" stroke="#FFFFFF" stroke-width="1.2"/>
      <path d="M 8 14 Q 12 10 16 14" stroke="#48BB78" stroke-width="2" fill="none"/>
      <path d="M 24 14 Q 28 10 32 14" stroke="#48BB78" stroke-width="2" fill="none"/>
      <path d="M 4 12 Q 12 4 20 12" stroke="#48BB78" stroke-width="2" fill="none"/>
      <path d="M 20 12 Q 28 4 36 12" stroke="#48BB78" stroke-width="2" fill="none"/>
    </symbol>
    <!-- icReport: 報表 -->
    <symbol id="icReport" viewBox="0 0 40 40">
      <rect x="6" y="6" width="22" height="28" rx="2" fill="#FFFFFF" stroke="#4A5568" stroke-width="1.5"/>
      <line x1="10" y1="13" x2="24" y2="13" stroke="#4A5568" stroke-width="1.5"/>
      <line x1="10" y1="17" x2="24" y2="17" stroke="#4A5568" stroke-width="1.5"/>
      <rect x="10" y="22" width="3" height="8" fill="#3182CE"/>
      <rect x="14" y="20" width="3" height="10" fill="#3182CE"/>
      <rect x="18" y="24" width="3" height="6" fill="#3182CE"/>
      <rect x="22" y="18" width="3" height="12" fill="#3182CE"/>
      <path d="M 28 6 L 36 6 L 36 14 Z" fill="#A0AEC0"/>
    </symbol>
  </defs>

  <!-- Title -->
  <text x="700" y="40" text-anchor="middle" font-size="28" font-weight="bold" fill="#1A202C">玉山 Outreach 案 — 整體架構</text>
  <text x="700" y="68" text-anchor="middle" font-size="14" fill="#4A5568">VOXEN + 3CX + 沿用瑛聲既有資產 整合方案</text>

  <!-- ==================== L0: USERS ==================== -->
  <rect x="50" y="100" width="1300" height="100" rx="10" fill="url(#gUser)" stroke="#A0AEC0" stroke-width="1.5"/>
  <text x="70" y="125" font-size="14" font-weight="bold" fill="#4A5568">使用者層  ·  Users</text>

  <g filter="url(#shadow)">
    <rect x="200" y="115" width="180" height="75" rx="8" fill="#FFFFFF" stroke="#4A5568" stroke-width="1.5"/>
  </g>
  <use href="#icAgent" x="215" y="135" width="40" height="40"/>
  <text x="320" y="153" text-anchor="middle" font-size="14" font-weight="bold" fill="#1A202C">450 外撥座席</text>
  <text x="320" y="172" text-anchor="middle" font-size="11" fill="#4A5568">電話銷售 + 債務管理</text>

  <g filter="url(#shadow)">
    <rect x="430" y="115" width="180" height="75" rx="8" fill="#FFFFFF" stroke="#4A5568" stroke-width="1.5"/>
  </g>
  <use href="#icSup" x="445" y="135" width="40" height="40"/>
  <text x="550" y="153" text-anchor="middle" font-size="14" font-weight="bold" fill="#1A202C">主管 / 隊長</text>
  <text x="550" y="172" text-anchor="middle" font-size="11" fill="#4A5568">即時監控 + 介入</text>

  <g filter="url(#shadow)">
    <rect x="660" y="115" width="180" height="75" rx="8" fill="#FFFFFF" stroke="#4A5568" stroke-width="1.5"/>
  </g>
  <use href="#icCust" x="675" y="135" width="40" height="40"/>
  <text x="780" y="153" text-anchor="middle" font-size="14" font-weight="bold" fill="#1A202C">客戶</text>
  <text x="780" y="172" text-anchor="middle" font-size="11" fill="#4A5568">外撥對象</text>

  <g filter="url(#shadow)">
    <rect x="890" y="115" width="180" height="75" rx="8" fill="#FFFFFF" stroke="#4A5568" stroke-width="1.5"/>
  </g>
  <use href="#icAudit" x="905" y="135" width="40" height="40"/>
  <text x="1010" y="153" text-anchor="middle" font-size="14" font-weight="bold" fill="#1A202C">質檢 / IT / 稽核</text>
  <text x="1010" y="172" text-anchor="middle" font-size="11" fill="#4A5568">後勤管理</text>

  <!-- ==================== L1: 體驗層 ==================== -->
  <rect x="50" y="220" width="1300" height="135" rx="10" fill="url(#gExp)" stroke="#48BB78" stroke-width="2"/>
  <text x="70" y="245" font-size="14" font-weight="bold" fill="#22543D">體驗層  ·  沿用瑛聲既有 OPEN/TeleSA + 增強</text>

  <g filter="url(#shadow)">
    <rect x="100" y="260" width="280" height="80" rx="8" fill="url(#cardGreen)" stroke="#48BB78" stroke-width="2"/>
  </g>
  <use href="#icMonitor" x="115" y="280" width="44" height="44"/>
  <text x="270" y="285" text-anchor="middle" font-size="13" font-weight="bold" fill="#22543D">座席桌面（沿用 + 增強）</text>
  <text x="270" y="305" text-anchor="middle" font-size="10" fill="#22543D">OPEN/TeleSA 既有 UI</text>
  <text x="270" y="320" text-anchor="middle" font-size="10" fill="#22543D">+ 整合 3CX Call Control</text>
  <text x="270" y="334" text-anchor="middle" font-size="10" fill="#22543D">+ Hot-desking</text>

  <g filter="url(#shadow)">
    <rect x="430" y="260" width="280" height="80" rx="8" fill="url(#cardGreen)" stroke="#48BB78" stroke-width="2"/>
  </g>
  <use href="#icDashboard" x="445" y="280" width="44" height="44"/>
  <text x="600" y="285" text-anchor="middle" font-size="13" font-weight="bold" fill="#22543D">主管桌面（沿用 + 增強）</text>
  <text x="600" y="305" text-anchor="middle" font-size="10" fill="#22543D">OPEN/TeleSA 既有 UI</text>
  <text x="600" y="320" text-anchor="middle" font-size="10" fill="#22543D">+ 即時儀表板</text>
  <text x="600" y="334" text-anchor="middle" font-size="10" fill="#22543D">+ Whisper / Barge-in / Take-over</text>

  <g filter="url(#shadow)">
    <rect x="760" y="260" width="280" height="80" rx="8" fill="url(#cardGreen)" stroke="#48BB78" stroke-width="2"/>
  </g>
  <use href="#icRec" x="775" y="280" width="44" height="44"/>

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1400 900" font-family="Microsoft JhengHei, Noto Sans CJK TC, sans-serif">
  <!--
    Migration Strategy — Isometric v2 (升級版)
    從 Genesys 舊大樓搬遷到 VOXEN+3CX 新大樓
    Fix list: 減留白 / 拆除建造隱喻 / Pilot 試橋放大 / 並行緩衝強調 / 小人物升級 / 完整時間軸
  -->
  <defs>
    <linearGradient id="ground" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#EDF2F7"/>
      <stop offset="100%" stop-color="#CBD5E0"/>
    </linearGradient>
    <linearGradient id="genTop" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FC8181"/>
      <stop offset="100%" stop-color="#E53E3E"/>
    </linearGradient>
    <linearGradient id="genFront" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#E53E3E"/>
      <stop offset="100%" stop-color="#9B2C2C"/>
    </linearGradient>
    <linearGradient id="genRight" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#C53030"/>
      <stop offset="100%" stop-color="#742A2A"/>
    </linearGradient>
    <linearGradient id="voxTop" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#9AE6B4"/>
      <stop offset="100%" stop-color="#48BB78"/>
    </linearGradient>
    <linearGradient id="voxFront" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#48BB78"/>
      <stop offset="100%" stop-color="#22543D"/>
    </linearGradient>
    <linearGradient id="voxRight" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#2F855A"/>
      <stop offset="100%" stop-color="#1A3F2A"/>
    </linearGradient>
    <linearGradient id="bridgeTop" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FAF089"/>
      <stop offset="100%" stop-color="#D69E2E"/>
    </linearGradient>
    <linearGradient id="parallelZone" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FED7D7" stop-opacity="0.45"/>
      <stop offset="100%" stop-color="#FED7D7" stop-opacity="0.15"/>
    </linearGradient>

    <filter id="softShadow" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="3"/>
      <feOffset dx="3" dy="6" result="offsetblur"/>
      <feComponentTransfer><feFuncA type="linear" slope="0.25"/></feComponentTransfer>
      <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>

    <marker id="bigArrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#22543D"/>
    </marker>
    <marker id="paraArrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#C53030"/>
    </marker>
    <marker id="paraArrowStart" viewBox="0 0 10 10" refX="1" refY="5" markerWidth="7" markerHeight="7" orient="auto">
      <path d="M 10 0 L 0 5 L 10 10 z" fill="#C53030"/>
    </marker>
  </defs>

  <!-- Title (compressed to top) -->
  <text x="700" y="32" text-anchor="middle" font-size="26" font-weight="bold" fill="#1A202C">Migration Strategy — 雙系統並行 + 分批切換</text>
  <text x="700" y="55" text-anchor="middle" font-size="13" fill="#4A5568">從 Genesys 舊系統搬遷至 VOXEN+3CX 新系統  ·  4 個月並行緩衝期 + Pilot 50 席試跑</text>

  <!-- ========= 並行緩衝 Zone（在底圖上方畫一個半透明區塊）========= -->
  <!-- W9 (06-30) 到 W26 (11-01) 之間 -->
  <rect x="725" y="90" width="320" height="495" fill="url(#parallelZone)" stroke="#C53030" stroke-width="1.5" stroke-dasharray="6,3" opacity="0.85"/>
  <text x="885" y="108" text-anchor="middle" font-size="11" font-weight="bold" fill="#C53030">並行緩衝期 4 個月</text>
  <line x1="730" y1="118" x2="1040" y2="118" stroke="#C53030" stroke-width="1.5" marker-end="url(#paraArrow)" marker-start="url(#paraArrowStart)"/>

  <!-- ============= 等距地面 ============= -->
  <polygon points="
    137,475
    916,475
    1263,675
    484,675
  " fill="url(#ground)" stroke="#A0AEC0" stroke-width="2"/>
  <g stroke="#A0AEC0" stroke-width="1" opacity="0.5">
    <line x1="298" y1="567" x2="1077" y2="567"/>
    <line x1="246" y1="537" x2="1025" y2="537"/>
    <line x1="194" y1="507" x2="973" y2="507"/>
  </g>

  <!-- ============= GENESYS 舊大樓（含拆除中元素）============= -->
  <g filter="url(#softShadow)">
    <polygon points="284,523 284,373 370,330 370,480" fill="url(#genRight)"/>
    <polygon points="198,480 198,330 284,373 284,523" fill="url(#genFront)"/>
    <polygon points="198,330 284,287 370,330 284,373" fill="url(#genTop)" stroke="#742A2A" stroke-width="1"/>
  </g>
  <!-- Genesys 窗戶（部分被拆，少了幾個） -->
  <g fill="#FFFFFF" opacity="0.6">
    <rect x="215" y="355" width="14" height="20"/>
    <rect x="240" y="370" width="14" height="20"/>
    <rect x="215" y="395" width="14" height="20"/>
    <rect x="240" y="408" width="14" height="20"/>
    <rect x="265" y="420" width="14" height="20"/>
    <rect x="215" y="435" width="14" height="20"/>
  </g>
  <!-- 「拆除」破損角 — 屋頂缺角 -->
  <polygon points="335,308 365,295 370,330 350,320" fill="#742A2A" opacity="0.6"/>
  <line x1="320" y1="315" x2="345" y2="305" stroke="#1A202C" stroke-width="1.2" opacity="0.7"/>
  <line x1="325" y1="320" x2="340" y2="310" stroke="#1A202C" stroke-width="1.2" opacity="0.7"/>
  <!-- 屋頂上的吊車（拆除中暗示）-->
  <g>
    <line x1="293" y1="287" x2="293" y2="240" stroke="#2D3748" stroke-width="2.5"/>
    <line x1="293" y1="240" x2="350" y2="240" stroke="#2D3748" stroke-width="2.5"/>
    <line x1="350" y1="240" x2="350" y2="270" stroke="#2D3748" stroke-width="1.5" stroke-dasharray="3,2"/>
    <rect x="345" y="270" width="10" height="8" fill="#4A5568"/>
    <line x1="293" y1="240" x2="288" y2="248" stroke="#2D3748" stroke-width="1.5"/>
    <line x1="293" y1="240" x2="298" y2="248" stroke="#2D3748" stroke-width="1.5"/>
    <text x="293" y="232" text-anchor="middle" font-size="9" fill="#742A2A" font-style="italic">拆除中</text>
  </g>
  <!-- Genesys 標籤 -->
  <g filter="url(#softShadow)">
    <rect x="155" y="178" width="180" height="40" rx="6" fill="#FFFFFF" stroke="#C53030" stroke-width="2"/>
  </g>
  <text x="245" y="198" text-anchor="middle" font-size="14" font-weight="bold" fill="#742A2A">Genesys Engage</text>
  <text x="245" y="213" text-anchor="middle" font-size="11" fill="#742A2A">舊系統 — 11/01 退場</text>

  <rect x="170" y="503" width="170" height="30" rx="4" fill="#742A2A"/>
  <text x="255" y="523" text-anchor="middle" font-size="12" font-weight="bold" fill="#FFFFFF">逐步縮減 → 退場</text>

  <!-- ============= VOXEN+3CX 新大樓（含建造中元素）============= -->
  <g filter="url(#softShadow)">
    <polygon points="1062,515 1062,335 1166,283 1166,463" fill="url(#voxRight)"/>
    <polygon points="958,463 958,283 1062,335 1062,515" fill="url(#voxFront)"/>
    <polygon points="958,283 1062,231 1166,283 1062,335" fill="url(#voxTop)" stroke="#22543D" stroke-width="1"/>
  </g>
  <!-- VOXEN 窗戶（完整） -->
  <g fill="#FFFFFF" opacity="0.7">
    <rect x="975" y="310" width="14" height="20"/>
    <rect x="1000" y="323" width="14" height="20"/>
    <rect x="1025" y="336" width="14" height="20"/>
    <rect x="975" y="350" width="14" height="20"/>
    <rect x="1000" y="363" width="14" height="20"/>
    <rect x="1025" y="376" width="14" height="20"/>
    <rect x="975" y="390" width="14" height="20"/>
    <rect x="1000" y="403" width="14" height="20"/>
    <rect x="1025" y="416" width="14" height="20"/>
    <rect x="975" y="430" width="14" height="20"/>
    <rect x="1000" y="443" width="14" height="20"/>
    <rect x="1025" y="456" width="14" height="20"/>
  </g>
  <!-- 鷹架（建造中暗示） — 在右側面 -->
  <g stroke="#A0AEC0" stroke-width="1.5" opacity="0.9" fill="none">
    <line x1="1080" y1="330" x2="1170" y2="285"/>
    <line x1="1080" y1="370" x2="1170" y2="325"/>
    <line x1="1080" y1="410" x2="1170" y2="365"/>
    <line x1="1090" y1="320" x2="1090" y2="490"/>
    <line x1="1110" y1="310" x2="1110" y2="480"/>
    <line x1="1130" y1="300" x2="1130" y2="470"/>
    <line x1="1150" y1="290" x2="1150" y2="460"/>
  </g>
  <text x="1115" y="465" text-anchor="middle" font-size="9" fill="#22543D" font-style="italic" font-weight="bold">建造中</text>
  <!-- VOXEN 標籤 -->
  <g filter="url(#softShadow)">
    <rect x="935" y="178" width="180" height="40" rx="6" fill="#FFFFFF" stroke="#22543D" stroke-width="2"/>
  </g>
  <text x="1025" y="198" text-anchor="middle" font-size="14" font-weight="bold" fill="#22543D">VOXEN + 3CX</text>
  <text x="1025" y="213" text-anchor="middle" font-size="11" fill="#22543D">新系統 — 06-30 Go-live</text>

  <rect x="950" y="485" width="170" height="30" rx="4" fill="#22543D"/>
  <text x="1035" y="505" text-anchor="middle" font-size="12" font-weight="bold" fill="#FFFFFF">逐步擴大 → 全量</text>

  <!-- ============= MIGRATION BRIDGE 主搬遷路徑 ============= -->
  <g filter="url(#softShadow)">
    <polygon points="355,395 943,395 990,413 402,413" fill="url(#bridgeTop)" stroke="#B7791F" stroke-width="1.5"/>
    <polygon points="402,413 990,413 990,427 402,427" fill="#B7791F"/>
  </g>
  <g stroke="#744210" stroke-width="0.6">
    <line x1="450" y1="395" x2="497" y2="413"/>
    <line x1="550" y1="395" x2="597" y2="413"/>
    <line x1="650" y1="395" x2="697" y2="413"/>
    <line x1="750" y1="395" x2="797" y2="413"/>
    <line x1="850" y1="395" x2="897" y2="413"/>
  </g>

  <!-- 里程碑旗子 -->
  <g>
    <line x1="475" y1="395" x2="475" y2="360" stroke="#D69E2E" stroke-width="2"/>
    <polygon points="475,360 510,367 475,375" fill="#F6E05E" stroke="#B7791F" stroke-width="1"/>
    <text x="475" y="353" text-anchor="middle" font-size="9" fill="#744210" font-weight="bold">SIT</text>

    <line x1="555" y1="395" x2="555" y2="360" stroke="#D69E2E" stroke-width="2"/>
    <polygon points="555,360 590,367 555,375" fill="#F6E05E" stroke="#B7791F" stroke-width="1"/>
    <text x="555" y="353" text-anchor="middle" font-size="9" fill="#744210" font-weight="bold">UAT</text>

    <line x1="635" y1="395" x2="635" y2="360" stroke="#D69E2E" stroke-width="2"/>
    <polygon points="635,360 670,367 635,375" fill="#F6E05E" stroke="#B7791F" stroke-width="1"/>
    <text x="635" y="353" text-anchor="middle" font-size="9" fill="#744210" font-weight="bold">PAT</text>

    <line x1="725" y1="395" x2="725" y2="335" stroke="#C53030" stroke-width="3.5"/>
    <polygon points="725,335 765,322 765,348 725,360" fill="#E53E3E" stroke="#742A2A" stroke-width="1.5"/>
    <text x="725" y="318" text-anchor="middle" font-size="12" font-weight="bold" fill="#C53030">★ Go-live</text>
    <text x="725" y="305" text-anchor="middle" font-size="10" fill="#C53030">06-30</text>

    <line x1="820" y1="395" x2="820" y2="360" stroke="#48BB78" stroke-width="2"/>
    <polygon points="820,360 855,367 820,375" fill="#9AE6B4" stroke="#22543D" stroke-width="1"/>
    <text x="820" y="353" text-anchor="middle" font-size="9" fill="#22543D" font-weight="bold">Pilot 通過</text>

    <line x1="900" y1="395" x2="900" y2="360" stroke="#48BB78" stroke-width="2"/>
    <polygon points="900,360 935,367 900,375" fill="#9AE6B4" stroke="#22543D" stroke-width="1"/>
    <text x="900" y="353" text-anchor="middle" font-size="9" fill="#22543D" font-weight="bold">全量</text>
  </g>

  <!-- 走在橋上的小人物（升級版 — 加手臂） -->
  <g fill="#2D3748">
    <!-- Figure 1 -->
    <circle cx="430" cy="402" r="3.2"/>
    <line x1="430" y1="405" x2="430" y2="416" stroke="#2D3748" stroke-width="2"/>
    <line x1="430" y1="408" x2="426" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <line x1="430" y1="408" x2="434" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <!-- Figure 2 -->
    <circle cx="500" cy="402" r="3.2"/>
    <line x1="500" y1="405" x2="500" y2="416" stroke="#2D3748" stroke-width="2"/>
    <line x1="500" y1="408" x2="496" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <line x1="500" y1="408" x2="504" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <!-- Figure 3 -->
    <circle cx="580" cy="402" r="3.2"/>
    <line x1="580" y1="405" x2="580" y2="416" stroke="#2D3748" stroke-width="2"/>
    <line x1="580" y1="408" x2="576" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <line x1="580" y1="408" x2="584" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <!-- Figure 4 -->
    <circle cx="660" cy="402" r="3.2"/>
    <line x1="660" y1="405" x2="660" y2="416" stroke="#2D3748" stroke-width="2"/>
    <line x1="660" y1="408" x2="656" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <line x1="660" y1="408" x2="664" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <!-- Figure 5 -->
    <circle cx="780" cy="402" r="3.2"/>
    <line x1="780" y1="405" x2="780" y2="416" stroke="#2D3748" stroke-width="2"/>
    <line x1="780" y1="408" x2="776" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <line x1="780" y1="408" x2="784" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <!-- Figure 6 -->
    <circle cx="860" cy="402" r="3.2"/>
    <line x1="860" y1="405" x2="860" y2="416" stroke="#2D3748" stroke-width="2"/>
    <line x1="860" y1="408" x2="856" y2="412" stroke="#2D3748" stroke-width="1.5"/>
    <line x1="860" y1="408" x2="864" y2="412" stroke="#2D3748" stroke-width="1.5"/>
  </g>
  <!-- Migration arrow -->
  <path d="M 380 388 Q 670 376 970 388" fill="none" stroke="#22543D" stroke-width="2.5" marker-end="url(#bigArrow)" stroke-dasharray="6,3" opacity="0.6"/>
  <text x="690" y="383" text-anchor="middle" font-size="11" font-style="italic" fill="#22543D" font-weight="bold">Migration（450 席分批搬遷）</text>

  <!-- ============= PILOT 50 席「試橋」（放大）============= -->
  <g filter="url(#softShadow)">
    <polygon points="600,475 850,475 875,490 625,490" fill="#9AE6B4" stroke="#22543D" stroke-width="2"/>
    <polygon points="625,490 875,490 875,505 625,505" fill="#48BB78"/>
  </g>
  <!-- Pilot 50 figures (3 small) -->
  <g fill="#2D3748">
    <circle cx="685" cy="473" r="3"/>
    <line x1="685" y1="476" x2="685" y2="486" stroke="#2D3748" stroke-width="1.8"/>
    <circle cx="735" cy="473" r="3"/>
    <line x1="735" y1="476" x2="735" y2="486" stroke="#2D3748" stroke-width="1.8"/>
    <circle cx="785" cy="473" r="3"/>
    <line x1="785" y1="476" x2="785" y2="486" stroke="#2D3748" stroke-width="1.8"/>
  </g>
  <text x="737" y="467" text-anchor="middle" font-size="12" font-weight="bold" fill="#22543D">Pilot 50 席（2 週試跑）</text>
  <text x="737" y="525" text-anchor="middle" font-size="10" fill="#22543D" font-style="italic">試跑通過才走主橋  ·  爆破半徑 ÷ 9</text>

  <!-- ============= 完整時間軸（地面下方）============= -->
  <line x1="200" y1="715" x2="1200" y2="715" stroke="#4A5568" stroke-width="2"/>
  <g font-size="10" fill="#4A5568">
    <line x1="220" y1="710" x2="220" y2="720" stroke="#4A5568" stroke-width="2"/>
    <text x="220" y="734" text-anchor="middle">W0</text>
    <text x="220" y="746" text-anchor="middle">04-26</text>

    <line x1="380" y1="710" x2="380" y2="720" stroke="#4A5568" stroke-width="2"/>
    <text x="380" y="734" text-anchor="middle">W6</text>
    <text x="380" y="746" text-anchor="middle">06-08 SIT</text>

    <line x1="455" y1="710" x2="455" y2="720" stroke="#4A5568" stroke-width="2"/>
    <text x="455" y="734" text-anchor="middle">W7</text>
    <text x="455" y="746" text-anchor="middle">06-15 UAT</text>

    <line x1="530" y1="710" x2="530" y2="720" stroke="#4A5568" stroke-width="2"/>
    <text x="530" y="734" text-anchor="middle">W8</text>
    <text x="530" y="746" text-anchor="middle">06-22 PAT</text>

    <line x1="610" y1="705" x2="610" y2="725" stroke="#C53030" stroke-width="3"/>
    <text x="610" y="734" text-anchor="middle" font-weight="bold" fill="#C53030">W9 ★</text>
    <text x="610" y="746" text-anchor="middle" font-weight="bold" fill="#C53030">06-30 Go-live</text>

    <line x1="800" y1="710" x2="800" y2="720" stroke="#4A5568" stroke-width="2"/>
    <text x="800" y="734" text-anchor="middle">W12</text>
    <text x="800" y="746" text-anchor="middle">07-20 擴大</text>

    <line x1="940" y1="710" x2="940" y2="720" stroke="#4A5568" stroke-width="2"/>
    <text x="940" y="734" text-anchor="middle">W15</text>
    <text x="940" y="746" text-anchor="middle">08-16 全量</text>

    <line x1="1080" y1="710" x2="1080" y2="720" stroke="#4A5568" stroke-width="2"/>
    <text x="1080" y="734" text-anchor="middle">W22</text>
    <text x="1080" y="746" text-anchor="middle">09-28 BAU</text>

    <line x1="1180" y1="705" x2="1180" y2="725" stroke="#C53030" stroke-width="3"/>
    <text x="1180" y="734" text-anchor="middle" font-weight="bold" fill="#C53030">W26 ★</text>
    <text x="1180" y="746" text-anchor="middle" font-weight="bold" fill="#C53030">11-01 Genesys 退場</text>
  </g>

  <!-- ============= 三層安全網 ============= -->
  <g filter="url(#softShadow)">
    <rect x="80" y="775" width="1240" height="105" rx="12" fill="#FFFFFF" stroke="#3182CE" stroke-width="2"/>
  </g>
  <text x="100" y="800" font-size="14" font-weight="bold" fill="#2C5282">三層安全網  ·  Three Layers of Safety（即使最壞情況下，影響面也限縮 + 可快速回滾）</text>

  <!-- Net 1 -->
  <g filter="url(#softShadow)">
    <polygon points="155,830 195,815 235,830 235,860 195,880 155,860" fill="#48BB78" stroke="#22543D" stroke-width="2"/>
    <polygon points="155,830 195,847 235,830 195,815" fill="#9AE6B4" stroke="#22543D" stroke-width="1"/>
  </g>
  <text x="195" y="850" text-anchor="middle" font-size="18" font-weight="bold" fill="#FFFFFF">1</text>
  <text x="270" y="833" font-size="13" font-weight="bold" fill="#22543D">Pilot 50 席（生產試跑）</text>
  <text x="270" y="850" font-size="11" fill="#22543D">爆破半徑 ÷ 9（450 → 50）</text>
  <text x="270" y="867" font-size="10" fill="#22543D" font-style="italic">通過才擴大全量</text>

  <line x1="490" y1="845" x2="540" y2="845" stroke="#4A5568" stroke-width="1.5" stroke-dasharray="4,3"/>
  <text x="515" y="840" text-anchor="middle" font-size="10" font-style="italic" fill="#4A5568">疊加</text>

  <!-- Net 2 -->
  <g filter="url(#softShadow)">
    <polygon points="565,830 605,815 645,830 645,860 605,880 565,860" fill="#3182CE" stroke="#2C5282" stroke-width="2"/>
    <polygon points="565,830 605,847 645,830 605,815" fill="#63B3ED" stroke="#2C5282" stroke-width="1"/>
  </g>
  <text x="605" y="850" text-anchor="middle" font-size="18" font-weight="bold" fill="#FFFFFF">2</text>
  <text x="680" y="833" font-size="13" font-weight="bold" fill="#2C5282">Parallel Run 4 個月</text>
  <text x="680" y="850" font-size="11" fill="#2C5282">舊系統留至 11-01 才退</text>
  <text x="680" y="867" font-size="10" fill="#2C5282" font-style="italic">隨時可 Rollback</text>

  <line x1="900" y1="845" x2="950" y2="845" stroke="#4A5568" stroke-width="1.5" stroke-dasharray="4,3"/>
  <text x="925" y="840" text-anchor="middle" font-size="10" font-style="italic" fill="#4A5568">疊加</text>

  <!-- Net 3 -->
  <g filter="url(#softShadow)">
    <polygon points="975,830 1015,815 1055,830 1055,860 1015,880 975,860" fill="#DD6B20" stroke="#7C2D12" stroke-width="2"/>
    <polygon points="975,830 1015,847 1055,830 1015,815" fill="#F6AD55" stroke="#7C2D12" stroke-width="1"/>
  </g>
  <text x="1015" y="850" text-anchor="middle" font-size="18" font-weight="bold" fill="#FFFFFF">3</text>
  <text x="1090" y="833" font-size="13" font-weight="bold" fill="#7C2D12">分批切換（不 Big Bang）</text>
  <text x="1090" y="850" font-size="11" fill="#7C2D12">50 → 100 → 200 → 450</text>
  <text x="1090" y="867" font-size="10" fill="#7C2D12" font-style="italic">每批通過才進下一批</text>

  <text x="700" y="895" text-anchor="middle" font-size="10" font-style="italic" fill="#4A5568">本圖為 isometric prototype  ·  正式 Pitch 版另由設計師繪製（詳 DESIGN-BRIEF-for-illustrator.md）</text>
</svg>

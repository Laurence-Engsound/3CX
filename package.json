{
  "name": "voxen-platform",
  "version": "0.1.0",
  "private": true,
  "description": "VOXEN Customer Engagement Platform — monorepo root",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --parallel run build",
    "test": "pnpm -r --parallel run test",
    "typecheck": "pnpm -r --parallel run typecheck",
    "dev:3cx": "pnpm --filter @voxen/pbx-3cx run dev",
    "smoke:3cx": "pnpm --filter @voxen/pbx-3cx run smoke",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
